<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Override Android 12+ splash screen to match app's custom splash (dark) -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <!-- API 31+: hide system icon, match background color -->
        <item name="android:windowSplashScreenBackground">#000000</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_splash_blank</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#000000</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
